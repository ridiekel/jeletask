{
  "extends": [
    "config:recommended",
    "group:springBoot",
    "group:springCore"
  ],
  "enabledManagers": [
    "maven",
    "gitlabci",
    "maven-wrapper"
  ],
  "commitBody": "Renovate Bot <bot@renovateapp.com>",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "rebaseWhen": "auto"
    }
  ]
}
